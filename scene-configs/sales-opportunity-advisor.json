{
  "scene": "sales-opportunity-advisor",
  "enabled": true,
  "title": "销售机会推进建议（helper）",
  "description": "通过 ContextHelper 数据 tool 获取销售机会 rawRow，由主 skill 完成字段清洗、字典映射、建议生成和结构化输出校验。",
  "execution": {
    "mode": "agent-runtime"
  },
  "routing": {
    "mode": "langgraph",
    "allowedModes": [
      "langgraph"
    ],
    "langgraphCutover": {
      "requestPercentage": 100
    }
  },
  "agent": {
    "id": "project-sales-opportunity-advisor",
    "gatewayModel": "project/sales-opportunity-advisor",
    "sessionKeyPrefix": "agent:project-sales-opportunity-advisor:api"
  },
  "runtime": {
    "requestKind": "sales_opportunity_advisor_request",
    "messageVersion": "1.0",
    "requestMarkers": {
      "begin": "<<<SALES_OPPORTUNITY_ADVISOR_REQUEST_JSON_BEGIN>>>",
      "end": "<<<SALES_OPPORTUNITY_ADVISOR_REQUEST_JSON_END>>>"
    },
    "resultMarkers": {
      "begin": "<<<SALES_OPPORTUNITY_ADVISOR_RESULT_JSON_BEGIN>>>",
      "end": "<<<SALES_OPPORTUNITY_ADVISOR_RESULT_JSON_END>>>"
    },
    "responseFormat": {
      "type": "json",
      "schemaVersion": "1.0"
    }
  },
  "request": {
    "bizParams": {
      "opportunityId": {
        "type": "opportunityId",
        "required": true
      }
    }
  },
  "skill": {
    "id": "sales-opportunity-advisor",
    "type": "project-query-contract",
    "workspacePath": "project://references/sales-opportunity-advisor",
    "entryFile": "project://references/sales-opportunity-advisor/skill_contract.md",
    "responsibility": "提供销售机会推进建议输入输出契约与受控查询定义；业务编排由 platform BusinessSkill 与项目内 LangGraph 执行。",
    "version": "v1"
  },
  "tools": [
    {
      "id": "sales-opportunity-context-helper",
      "type": "data-tool",
      "binding": "http",
      "endpoint": "http://127.0.0.1:19101/internal/context/sales-opportunity",
      "responseContract": "rawRow",
      "params": [
        "requestId",
        "opportunityId"
      ]
    },
    {
      "id": "sales-opportunity-model-tool",
      "type": "model-tool",
      "binding": "http",
      "endpoint": "http://127.0.0.1:19103/internal/model/validate-structured-output",
      "responseContract": "validatedPayload",
      "params": [
        "requestId",
        "scene",
        "payload",
        "schema"
      ]
    }
  ],
  "references": [
    {
      "id": "sales-opportunity-dictionary",
      "type": "local-file",
      "path": "project://metadata/sales_opportunity_dictionary.tsv",
      "purpose": "字段名、字段描述、枚举解释、格式化说明"
    },
    {
      "id": "sales-opportunity-decision-rules",
      "type": "local-file",
      "path": "project://references/sales-opportunity-advisor/decision_rules.md",
      "purpose": "销售推进建议规则"
    },
    {
      "id": "sales-opportunity-output-schema",
      "type": "local-file",
      "path": "project://references/sales-opportunity-advisor/output_schema.json",
      "purpose": "业务结构化输出 schema"
    }
  ],
  "orchestration": [
    {
      "order": 1,
      "step": "parse-request",
      "owner": "skill",
      "description": "解析 runtime request，校验 scene、kind、version、opportunityId。"
    },
    {
      "order": 2,
      "step": "fetch-raw-row",
      "owner": "data-tool",
      "toolId": "sales-opportunity-context-helper",
      "description": "通过 helper 数据 tool 获取销售机会 rawRow。"
    },
    {
      "order": 3,
      "step": "load-references",
      "owner": "skill",
      "description": "读取本地字典文件、规则文件和输出 schema。"
    },
    {
      "order": 4,
      "step": "normalize-fields",
      "owner": "skill",
      "description": "在 skill 内完成字段过滤、字典映射、profile/facts 生成。"
    },
    {
      "order": 5,
      "step": "generate-advice",
      "owner": "skill",
      "description": "基于事实和业务规则生成建议 payload。"
    },
    {
      "order": 6,
      "step": "validate-output",
      "owner": "model-tool",
      "toolId": "sales-opportunity-model-tool",
      "description": "调用模型结构化输出 tool 校验 payload 是否符合 schema。"
    },
    {
      "order": 7,
      "step": "return-result",
      "owner": "skill",
      "description": "返回 wrapped result JSON。"
    }
  ]
}
