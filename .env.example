# API server binding.
API_HOST=0.0.0.0
API_PORT=3000

# Local helper service ports.
CONTEXT_HELPER_PORT=19001
DIRECTDB_RUNNER_PORT=19002
MODEL_TOOL_PORT=19003

# RAG service.
RAG_SEARCH_HOST=127.0.0.1
RAG_SEARCH_PORT=19104
RAG_SERVICE_BASE_URL=http://127.0.0.1:19104
RAG_PROXY_TIMEOUT_MS=15000
RAG_COLLECTION_NAME=

# Embedding.
DASHSCOPE_API_KEY=replace-with-dashscope-api-key
EMBEDDING_MODEL=text-embedding-v4

# Optional chat config for future RAG management features.
CHAT_MODEL=
CHAT_BASE_URL=
CHAT_API_KEY=

# Optional DB sync connection. Prefer env:XXX in UI configs.
RAG_SYNC_DB_URL=

# API keys and tokens.
OPENCLAW_GATEWAY_TOKEN=replace-with-openclaw-gateway-token
MOONSHOT_API_KEY=replace-with-moonshot-api-key
DEEPSEEK_API_KEY=replace-with-deepseek-api-key

# Gateway/runtime settings.
GATEWAY_TIMEOUT_MS=120000
API_WRITE_DEBUG_SNAPSHOTS=0

# SQL Server connection.
SQLSERVER_HOST=replace-with-sqlserver-host
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=replace-with-sqlserver-database
SQLSERVER_USER=replace-with-sqlserver-user
SQLSERVER_PASSWORD=replace-with-sqlserver-password
SQLSERVER_ENCRYPT=0
SQLSERVER_TRUST_CERT=1
SQLSERVER_POOL_MAX=5
SQLSERVER_IDLE_TIMEOUT_MS=30000
SQLSERVER_REQUEST_TIMEOUT_MS=120000
SQLSERVER_CONNECTION_TIMEOUT_MS=15000

# MySQL connection.
MYSQL_HOST=replace-with-mysql-host
MYSQL_PORT=3306
MYSQL_USER=replace-with-mysql-user
MYSQL_PASSWORD=replace-with-mysql-password
MYSQL_DATABASE=replace-with-mysql-database
