# API 与本地工具服务端口。
API_HOST=0.0.0.0
API_PORT=3100
CONTEXT_HELPER_PORT=19101
DIRECTDB_RUNNER_PORT=19102
MODEL_TOOL_PORT=19103

# 发布运行态。production/prod 会强制读取 active bundle；本地可设置 1 提前演练。
CONFIG_ACTIVE_ENV=local
CONFIG_REQUIRE_ACTIVE_BUNDLE=0
# CONFIG_BUNDLE_ROOT=/data/agent-platform/runtime-bundles
# CONFIG_CURRENT_BUNDLE=/data/agent-platform/runtime-bundles/prod/current

# 控制台写操作保护。生产环境必须配置，前端请求需带 X-Console-Admin-Token 或 Bearer token。
CONSOLE_ADMIN_TOKEN=

# LangGraph 项目内大模型。需要真实调用模型时使用 project-llm。
LANGGRAPH_DRAFT_MODE=project-llm
LANGGRAPH_LLM_PROVIDER=deepseek
LANGGRAPH_LLM_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=replace-with-deepseek-api-key

# Moonshot 仅用于 SQL / 查询模板生成路径。
MOONSHOT_API_KEY=replace-with-moonshot-api-key

# RAG 语义检索。只有使用外部 RAG 数据目录时才需要 RAG_DATA_DIR。
DASHSCOPE_API_KEY=replace-with-dashscope-api-key
# RAG_DATA_DIR=/absolute/path/to/rag-data

# SQL Server 业务数据源。
SQLSERVER_HOST=replace-with-sqlserver-host
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=replace-with-sqlserver-database
SQLSERVER_USER=replace-with-sqlserver-user
SQLSERVER_PASSWORD=replace-with-sqlserver-password

# MySQL 配置中心。
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=replace-with-mysql-user
MYSQL_PASSWORD=replace-with-mysql-password
MYSQL_DATABASE=config_center_dev
