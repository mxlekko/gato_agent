# 复制到项目根目录 .env 后再执行 docker compose。

# API 与本地工具服务端口。
API_PORT=3100
CONTEXT_HELPER_PORT=19101
DIRECTDB_RUNNER_PORT=19102
MODEL_TOOL_PORT=19103

# LangGraph 项目内大模型。
LANGGRAPH_DRAFT_MODE=project-llm
LANGGRAPH_LLM_PROVIDER=deepseek
LANGGRAPH_LLM_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=replace-with-deepseek-api-key

# Moonshot 仅用于 SQL / 查询模板生成路径。
MOONSHOT_API_KEY=replace-with-moonshot-api-key

# RAG 语义检索。
DASHSCOPE_API_KEY=replace-with-dashscope-api-key

# SQL Server 业务数据源。云服务器必须能连到这个地址。
SQLSERVER_HOST=replace-with-sqlserver-host
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=replace-with-sqlserver-database
SQLSERVER_USER=replace-with-sqlserver-user
SQLSERVER_PASSWORD=replace-with-sqlserver-password

# Compose 内置 MySQL 配置中心。
MYSQL_ROOT_PASSWORD=replace-with-root-password
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=cfg_app_dev
MYSQL_PASSWORD=replace-with-config-center-password
MYSQL_DATABASE=config_center_dev
